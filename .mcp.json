{
  "mcpServers": {
    "brave-devtools": {
      "command": "./scripts/brave-devtools-mcp.sh",
      "args": [
        "--isolated",
        "--viewport", "1920x1080",
        "--acceptInsecureCerts",
        "--no-usage-statistics",
        "--logFile", "/tmp/chrome-devtools-mcp--ralph-monitor.log"
      ],
      "env": {
        "DEBUG": "",
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1"
      }
    }
  }
}